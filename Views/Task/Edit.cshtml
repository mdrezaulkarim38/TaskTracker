@model TaskTracker.Models.ViewModels.TaskFormViewModel

@{
    ViewData["Title"] = "Edit Task";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">
            <div class="card border-1 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="mb-4">
                        <h2 class="fw-bold mb-1">Edit Task</h2>
                        <p class="text-muted mb-0">Update task details and keep everything organized.</p>
                    </div>

                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Title</label>
                            <input asp-for="Title" class="form-control rounded-3" placeholder="Enter task title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description"
                                      class="form-control rounded-3"
                                      rows="4"
                                      placeholder="Enter task description (optional)"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="DueDate" class="form-label fw-semibold">Due Date</label>
                                <input asp-for="DueDate" type="date" class="form-control rounded-3" />
                                <span asp-validation-for="DueDate" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Priority" class="form-label fw-semibold">Priority</label>
                                <select asp-for="Priority" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<Priority>()"></select>
                                <span asp-validation-for="Priority" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-check form-switch mt-4 mb-4">
                            <input asp-for="IsCompleted" class="form-check-input" />
                            <label asp-for="IsCompleted" class="form-check-label fw-semibold">Mark as completed</label>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-sm btn-warning px-4">
                                <i class="fa-solid fa-floppy-disk me-1"></i>Save Changes
                            </button>

                            <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-4">
                                <i class="fa-solid fa-arrow-left me-1"></i>Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}