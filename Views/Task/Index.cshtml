@model TaskTracker.Models.ViewModels.TaskListViewModel

@{
    ViewData["Title"] = "Task List";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">Task Tracker</h2>
            <p class="text-muted mb-0">Manage your tasks, track progress, and stay organized.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Create" class="btn btn-sm btn-primary btn-sm px-3">
                <i class="fa-solid fa-plus me-1"></i>Add Task
            </a>

            <a asp-action="ExportCsv"
                   asp-route-search="@Model.SearchTerm"
                   asp-route-status="@Model.FilterStatus"
                   asp-route-sort="@Model.SortOrder"
                   class="btn btn-success btn-sm px-3">
                <i class="fa-solid fa-file-csv me-1"></i>Export CSV
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card border-1 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Total Tasks</p>
                    <h3 class="fw-bold mb-0">@Model.TotalCount</h3>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-1 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Pending</p>
                    <h3 class="fw-bold text-warning mb-0">@Model.PendingCount</h3>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-1 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Completed</p>
                    <h3 class="fw-bold text-success mb-0">@Model.CompletedCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-1 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3 p-md-4">
            <form asp-action="Index" method="get" id="filterForm">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-lg-5">
                        <label class="form-label fw-semibold">Search</label>
                        <input type="text"
                               name="search"
                               id="searchInput"
                               class="form-control rounded-3"
                               placeholder="Search by title..."
                               value="@Model.SearchTerm" />
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Status</label>
                        <select name="status" id="statusFilter" class="form-select rounded-3">
                            <option value="">All Tasks</option>
                            <option value="pending" selected="@(Model.FilterStatus == "pending")">Pending</option>
                            <option value="completed" selected="@(Model.FilterStatus == "completed")">Completed</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Sort By</label>
                        <select name="sort" id="sortOrder" class="form-select rounded-3">
                            <option value="">Newest</option>
                            <option value="duedate" selected="@(Model.SortOrder == "duedate")">Due Date</option>
                            <option value="priority" selected="@(Model.SortOrder == "priority")">Priority</option>
                        </select>
                    </div>

                    <div class="col-12 col-lg-1 d-grid">
                        <button type="submit" class="btn btn-sm btn-primary rounded-3">
                            <i class="fa-solid fa-magnifying-glass me-1"></i>Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <form id="antiForgeryForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <div id="taskTableContainer">
        @await Html.PartialAsync("_TaskTablePartial", Model)
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center flex-wrap">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-start"
                           asp-action="Index"
                           asp-route-search="@Model.SearchTerm"
                           asp-route-status="@Model.FilterStatus"
                           asp-route-sort="@Model.SortOrder"
                           asp-route-page="@(Model.CurrentPage - 1)">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-search="@Model.SearchTerm"
                               asp-route-status="@Model.FilterStatus"
                               asp-route-sort="@Model.SortOrder"
                               asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-end"
                           asp-action="Index"
                           asp-route-search="@Model.SearchTerm"
                           asp-route-status="@Model.FilterStatus"
                           asp-route-sort="@Model.SortOrder"
                           asp-route-page="@(Model.CurrentPage + 1)">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script src="~/js/task.js" asp-append-version="true"></script>
}